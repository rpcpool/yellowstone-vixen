  uint32 collect_fee_mode = 9;
  uint32 migration_option = 10;
  uint32 activation_type = 11;
  uint32 token_decimal = 12;
  uint32 version = 13;
  uint32 token_type = 14;
  uint32 quote_token_flag = 15;
  uint32 partner_permanent_locked_liquidity_percentage = 16;
  uint32 partner_liquidity_percentage = 17;
  uint32 creator_permanent_locked_liquidity_percentage = 18;
  uint32 creator_liquidity_percentage = 19;
  uint32 migration_fee_option = 20;
  uint32 fixed_token_supply_flag = 21;
  uint32 creator_trading_fee_percentage = 22;
  uint32 token_update_authority = 23;
  uint32 migration_fee_percentage = 24;
  uint32 creator_migration_fee_percentage = 25;
  bytes padding2 = 26;
  uint64 swap_base_amount = 27;
  uint64 migration_quote_threshold = 28;
  uint64 migration_base_threshold = 29;
  bytes migration_sqrt_price = 30;
  LockedVestingConfig locked_vesting_config = 31;
  uint64 pre_migration_token_supply = 32;
  uint64 post_migration_token_supply = 33;
  uint32 migrated_collect_fee_mode = 34;
  uint32 migrated_dynamic_fee = 35;
  uint32 migrated_pool_fee_bps = 36;
  uint32 migrated_pool_base_fee_mode = 37;
  uint32 enable_first_swap_with_min_fee = 38;
  uint32 migrated_compounding_fee_bps = 39;
  uint64 pool_creation_fee = 40;
  bytes migrated_pool_base_fee_bytes = 41;
  bytes sqrt_start_price = 42;
  repeated LiquidityDistributionConfig curve = 43;
}
    
