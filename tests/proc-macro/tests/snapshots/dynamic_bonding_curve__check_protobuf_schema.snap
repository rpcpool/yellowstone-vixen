---
source: tests/proc-macro/tests/dynamic_bonding_curve.rs
expression: "dynamic_bonding_curve::PROTOBUF_SCHEMA"
---
syntax = "proto3";

package dynamic_bonding_curve;

message PublicKey {
  bytes value = 1;
}
    
message BaseFeeConfig {
  uint64 cliff_fee_numerator = 1;
  uint64 second_factor = 2;
  uint64 third_factor = 3;
  uint32 first_factor = 4;
  uint32 base_fee_mode = 5;
  bytes padding0 = 6;
}
    
message BaseFeeParameters {
  uint64 cliff_fee_numerator = 1;
  uint32 first_factor = 2;
  uint64 second_factor = 3;
  uint64 third_factor = 4;
  uint32 base_fee_mode = 5;
}
    
message ConfigParameters {
  PoolFeeParameters pool_fees = 1;
  uint32 collect_fee_mode = 2;
  uint32 migration_option = 3;
  uint32 activation_type = 4;
  uint32 token_type = 5;
  uint32 token_decimal = 6;
  uint32 partner_liquidity_percentage = 7;
  uint32 partner_permanent_locked_liquidity_percentage = 8;
  uint32 creator_liquidity_percentage = 9;
  uint32 creator_permanent_locked_liquidity_percentage = 10;
  uint64 migration_quote_threshold = 11;
  bytes sqrt_start_price = 12;
  LockedVestingParams locked_vesting = 13;
  uint32 migration_fee_option = 14;
  optional TokenSupplyParams token_supply = 15;
  uint32 creator_trading_fee_percentage = 16;
  uint32 token_update_authority = 17;
  MigrationFee migration_fee = 18;
  MigratedPoolFee migrated_pool_fee = 19;
  uint64 pool_creation_fee = 20;
  LiquidityVestingInfoParams partner_liquidity_vesting_info = 21;
  LiquidityVestingInfoParams creator_liquidity_vesting_info = 22;
  uint32 migrated_pool_base_fee_mode = 23;
  MigratedPoolMarketCapFeeSchedulerParams migrated_pool_market_cap_fee_scheduler_params = 24;
  bool enable_first_swap_with_min_fee = 25;
  uint32 compounding_fee_bps = 26;
  bytes padding = 27;
  repeated LiquidityDistributionParameters curve = 28;
}
    
message DynamicFeeConfig {
  uint32 initialized = 1;
  bytes padding = 2;
  uint32 max_volatility_accumulator = 3;
  uint32 variable_fee_control = 4;
  uint32 bin_step = 5;
  uint32 filter_period = 6;
  uint32 decay_period = 7;
  uint32 reduction_factor = 8;
  bytes padding2 = 9;
  bytes bin_step_u128 = 10;
}
    
message DynamicFeeParameters {
  uint32 bin_step = 1;
  bytes bin_step_u128 = 2;
  uint32 filter_period = 3;
  uint32 decay_period = 4;
  uint32 reduction_factor = 5;
  uint32 max_volatility_accumulator = 6;
  uint32 variable_fee_control = 7;
}
    
message InitializePoolParameters {
  string name = 1;
  string symbol = 2;
  string uri = 3;
}
    
message LiquidityDistributionConfig {
  bytes sqrt_price = 1;
  bytes liquidity = 2;
}
    
message LiquidityDistributionParameters {
  bytes sqrt_price = 1;
  bytes liquidity = 2;
}
    
message LiquidityVestingInfo {
  uint32 is_initialized = 1;
  uint32 vesting_percentage = 2;
  bytes padding = 3;
  uint32 bps_per_period = 4;
  uint32 number_of_periods = 5;
  uint32 frequency = 6;
  uint32 cliff_duration_from_migration_time = 7;
}
    
message LiquidityVestingInfoParams {
  uint32 vesting_percentage = 1;
  uint32 bps_per_period = 2;
  uint32 number_of_periods = 3;
  uint32 cliff_duration_from_migration_time = 4;
  uint32 frequency = 5;
}
    
message LockedVestingConfig {
  uint64 amount_per_period = 1;
  uint64 cliff_duration_from_migration_time = 2;
  uint64 frequency = 3;
  uint64 number_of_period = 4;
  uint64 cliff_unlock_amount = 5;
  uint64 padding = 6;
}
    
message LockedVestingParams {
  uint64 amount_per_period = 1;
  uint64 cliff_duration_from_migration_time = 2;
  uint64 frequency = 3;
  uint64 number_of_period = 4;
  uint64 cliff_unlock_amount = 5;
}
    
message MigratedPoolFee {
  uint32 collect_fee_mode = 1;
  uint32 dynamic_fee = 2;
  uint32 pool_fee_bps = 3;
}
    
message MigratedPoolMarketCapFeeSchedulerParams {
  uint32 number_of_period = 1;
  uint32 sqrt_price_step_bps = 2;
  uint32 scheduler_expiration_duration = 3;
  uint64 reduction_factor = 4;
}
    
message MigrationFee {
  uint32 fee_percentage = 1;
  uint32 creator_fee_percentage = 2;
}
    
message PoolFeeParameters {
  BaseFeeParameters base_fee = 1;
  optional DynamicFeeParameters dynamic_fee = 2;
}
    
message PoolFees {
  uint64 trade_fee_numerator = 1;
  uint64 trade_fee_denominator = 2;
  uint64 protocol_trade_fee_numerator = 3;
  uint64 protocol_trade_fee_denominator = 4;
}
    
message PoolFeesConfig {
  BaseFeeConfig base_fee = 1;
  DynamicFeeConfig dynamic_fee = 2;
}
    
message PoolMetrics {
  uint64 total_protocol_base_fee = 1;
  uint64 total_protocol_quote_fee = 2;
  uint64 total_trading_base_fee = 3;
  uint64 total_trading_quote_fee = 4;
}
    
message SwapParameters {
  uint64 amount_in = 1;
  uint64 minimum_amount_out = 2;
}
    
message SwapParameters2 {
  uint64 amount0 = 1;
  uint64 amount1 = 2;
  uint32 swap_mode = 3;
}
    
message TokenSupplyParams {
  uint64 pre_migration_token_supply = 1;
  uint64 post_migration_token_supply = 2;
}
    
message VolatilityTracker {
  uint64 last_update_timestamp = 1;
  bytes padding = 2;
  bytes sqrt_price_reference = 3;
  bytes volatility_accumulator = 4;
  bytes volatility_reference = 5;
}
    
message ClaimFeeOperator {
  PublicKey operator = 1;
  bytes padding = 2;
}
    
message Config {
