  uint32 padding3 = 15;
  uint32 padding4 = 16;
  bytes fee_growth_global0_x64 = 17;
  bytes fee_growth_global1_x64 = 18;
  uint64 protocol_fees_token0 = 19;
  uint64 protocol_fees_token1 = 20;
