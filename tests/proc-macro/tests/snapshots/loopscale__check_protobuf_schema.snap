message LoopscaleAccount {
  oneof account {
    Loan loan = 1;
    MarketInformation market_information = 2;
    PersonalPositionState personal_position_state = 3;
    PoolState pool_state = 4;
    Position position = 5;
    ProtocolPositionState protocol_position_state = 6;
    Strategy strategy = 7;
    Timelock timelock = 8;
    UserRewardsInfo user_rewards_info = 9;
    Vault vault = 10;
    VaultRewardsInfo vault_rewards_info = 11;
    VaultStake vault_stake = 12;
    Whirlpool whirlpool = 13;
  }
}
message LpParams {
  oneof kind {
    LpParamsExactIn exact_in = 1;
    LpParamsExactOut exact_out = 2;
  }
}
message TimelockUpdateParams {
  oneof kind {
    TimelockUpdateParamsAddCollateral add_collateral = 1;
    TimelockUpdateParamsUpdateLtv update_ltv = 2;
    TimelockUpdateParamsRemoveCollateral remove_collateral = 3;
    TimelockUpdateParamsUpdateApy update_apy = 4;
    TimelockUpdateParamsUpdateStrategy update_strategy = 5;
    TimelockUpdateParamsUpdateVault update_vault = 6;
    TimelockUpdateParamsUpdateCaps update_caps = 7;
    TimelockUpdateParamsUpdateCollateralAllocationPct update_collateral_allocation_pct = 8;
  }
}
message TransferTypeParams {
  oneof kind {
    TransferTypeParamsLiquidity liquidity = 1;
    TransferTypeParamsTokenAmounts token_amounts = 2;
  }
}
message Instructions {
  oneof instruction {
    BorrowPrincipal borrow_principal = 1;
    CancelTimelock cancel_timelock = 2;
    ClaimVaultFee claim_vault_fee = 3;
    ClaimVaultRewards claim_vault_rewards = 4;
    CloseLoan close_loan = 5;
    CloseStrategy close_strategy = 6;
    CreateLoan create_loan = 7;
    CreateMarketInformation create_market_information = 8;
    CreateRewardsSchedule create_rewards_schedule = 9;
    CreateStrategy create_strategy = 10;
    CreateTimelock create_timelock = 11;
    CreateVault create_vault = 12;
    DepositCollateral deposit_collateral = 13;
    DepositStrategy deposit_strategy = 14;
    DepositUserVault deposit_user_vault = 15;
    ExecuteTimelock execute_timelock = 16;
