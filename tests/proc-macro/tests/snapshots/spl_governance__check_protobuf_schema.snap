  optional int64 voting_at = 16;
  optional uint64 voting_at_slot = 17;
  optional int64 voting_completed_at = 18;
  optional int64 executing_at = 19;
  optional int64 closed_at = 20;
  InstructionExecutionFlags execution_flags = 21;
  optional uint64 max_vote_weight = 22;
  optional uint32 max_voting_time = 23;
  optional VoteThreshold vote_threshold = 24;
  bytes reserved = 25;
  string name = 26;
  string description_link = 27;
  uint64 veto_vote_weight = 28;
}
    
