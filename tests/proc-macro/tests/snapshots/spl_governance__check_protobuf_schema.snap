  PublicKey token_owner_record_lock_authority = 4;
  PublicKey payer = 5;
  PublicKey system_program = 6;
  repeated PublicKey remaining_accounts = 7;
}
    
message SetTokenOwnerRecordLockArgs {
  uint32 lock_id = 1;
  optional int64 expiry = 2;
}
    
message SetTokenOwnerRecordLock {
  SetTokenOwnerRecordLockAccounts accounts = 1;
  SetTokenOwnerRecordLockArgs args = 2;
}
    
message RelinquishTokenOwnerRecordLocksAccounts {
  PublicKey realm = 1;
  PublicKey realm_config = 2;
  PublicKey token_owner_record = 3;
  optional PublicKey token_owner_record_lock_authority = 4;
  repeated PublicKey remaining_accounts = 5;
}
    
message RelinquishTokenOwnerRecordLocksArgs {
  optional uint32 lock_ids = 1;
}
    
message RelinquishTokenOwnerRecordLocks {
  RelinquishTokenOwnerRecordLocksAccounts accounts = 1;
  RelinquishTokenOwnerRecordLocksArgs args = 2;
}
    
message SetRealmConfigItemAccounts {
  PublicKey realm = 1;
  PublicKey realm_config = 2;
  PublicKey realm_authority = 3;
  PublicKey payer = 4;
  PublicKey system_program = 5;
  repeated PublicKey remaining_accounts = 6;
}
    
message SetRealmConfigItem {
  SetRealmConfigItemAccounts accounts = 1;
  SetRealmConfigItemArgs args = 2;
}
    
message SplGovernanceAccount {
  oneof account {
    RealmV2 realm_v2 = 1;
    RealmConfigAccount realm_config_account = 2;
    GovernanceV2 governance_v2 = 3;
    ProposalV2 proposal_v2 = 4;
    ProposalTransactionV2 proposal_transaction_v2 = 5;
    SignatoryRecordV2 signatory_record_v2 = 6;
    VoteRecordV2 vote_record_v2 = 7;
    TokenOwnerRecordV2 token_owner_record_v2 = 8;
    ProgramMetadata program_metadata = 9;
    ProposalDeposit proposal_deposit = 10;
    RequiredSignatory required_signatory = 11;
    NativeTreasury native_treasury = 12;
  }
}
message GovernanceAccountType {
  oneof kind {
    GovernanceAccountTypeUninitialized uninitialized = 1;
    GovernanceAccountTypeRealmV1 realm_v1 = 2;
    GovernanceAccountTypeTokenOwnerRecordV1 token_owner_record_v1 = 3;
    GovernanceAccountTypeGovernanceV1 governance_v1 = 4;
    GovernanceAccountTypeProgramGovernanceV1 program_governance_v1 = 5;
    GovernanceAccountTypeProposalV1 proposal_v1 = 6;
    GovernanceAccountTypeSignatoryRecordV1 signatory_record_v1 = 7;
    GovernanceAccountTypeVoteRecordV1 vote_record_v1 = 8;
    GovernanceAccountTypeProposalInstructionV1 proposal_instruction_v1 = 9;
    GovernanceAccountTypeMintGovernanceV1 mint_governance_v1 = 10;
    GovernanceAccountTypeTokenGovernanceV1 token_governance_v1 = 11;
    GovernanceAccountTypeRealmConfig realm_config = 12;
    GovernanceAccountTypeVoteRecordV2 vote_record_v2 = 13;
    GovernanceAccountTypeProposalTransactionV2 proposal_transaction_v2 = 14;
    GovernanceAccountTypeProposalV2 proposal_v2 = 15;
    GovernanceAccountTypeProgramMetadata program_metadata = 16;
    GovernanceAccountTypeRealmV2 realm_v2 = 17;
    GovernanceAccountTypeTokenOwnerRecordV2 token_owner_record_v2 = 18;
    GovernanceAccountTypeGovernanceV2 governance_v2 = 19;
    GovernanceAccountTypeProgramGovernanceV2 program_governance_v2 = 20;
    GovernanceAccountTypeMintGovernanceV2 mint_governance_v2 = 21;
    GovernanceAccountTypeTokenGovernanceV2 token_governance_v2 = 22;
    GovernanceAccountTypeSignatoryRecordV2 signatory_record_v2 = 23;
    GovernanceAccountTypeProposalDeposit proposal_deposit = 24;
    GovernanceAccountTypeRequiredSignatory required_signatory = 25;
  }
}
message VoteThreshold {
  oneof kind {
    VoteThresholdYesVotePercentage yes_vote_percentage = 1;
    VoteThresholdQuorumPercentage quorum_percentage = 2;
    VoteThresholdDisabled disabled = 3;
  }
}
message VoteTipping {
  oneof kind {
    VoteTippingStrict strict = 1;
    VoteTippingEarly early = 2;
    VoteTippingDisabled disabled = 3;
  }
}
message GoverningTokenType {
  oneof kind {
    GoverningTokenTypeLiquid liquid = 1;
    GoverningTokenTypeMembership membership = 2;
    GoverningTokenTypeDormant dormant = 3;
  }
}
message MintMaxVoterWeightSource {
  oneof kind {
    MintMaxVoterWeightSourceSupplyFraction supply_fraction = 1;
    MintMaxVoterWeightSourceAbsolute absolute = 2;
  }
}
message SetRealmAuthorityAction {
  oneof kind {
    SetRealmAuthorityActionSetUnchecked set_unchecked = 1;
    SetRealmAuthorityActionSetChecked set_checked = 2;
    SetRealmAuthorityActionRemove remove = 3;
  }
}
message SetRealmConfigItemArgs {
  oneof kind {
    SetRealmConfigItemArgsTokenOwnerRecordLockAuthority token_owner_record_lock_authority = 1;
  }
}
message SetConfigItemActionType {
  oneof kind {
    SetConfigItemActionTypeAdd add = 1;
    SetConfigItemActionTypeRemove remove = 2;
  }
}
message VoteType {
  oneof kind {
    VoteTypeSingleChoice single_choice = 1;
    VoteTypeMultiChoice multi_choice = 2;
  }
}
message MultiChoiceType {
  oneof kind {
    MultiChoiceTypeFullWeight full_weight = 1;
    MultiChoiceTypeWeighted weighted = 2;
  }
}
message ProposalState {
  oneof kind {
    ProposalStateDraft draft = 1;
    ProposalStateSigningOff signing_off = 2;
    ProposalStateVoting voting = 3;
    ProposalStateSucceeded succeeded = 4;
    ProposalStateExecuting executing = 5;
    ProposalStateCompleted completed = 6;
    ProposalStateCancelled cancelled = 7;
    ProposalStateDefeated defeated = 8;
    ProposalStateExecutingWithErrors executing_with_errors = 9;
    ProposalStateVetoed vetoed = 10;
  }
}
message OptionVoteResult {
  oneof kind {
    OptionVoteResultNone none = 1;
    OptionVoteResultSucceeded succeeded = 2;
    OptionVoteResultDefeated defeated = 3;
  }
}
message InstructionExecutionFlags {
  oneof kind {
    InstructionExecutionFlagsNone none = 1;
    InstructionExecutionFlagsOrdered ordered = 2;
    InstructionExecutionFlagsUseTransaction use_transaction = 3;
  }
}
message TransactionExecutionStatus {
  oneof kind {
    TransactionExecutionStatusNone none = 1;
    TransactionExecutionStatusSuccess success = 2;
    TransactionExecutionStatusError error = 3;
  }
}
message Vote {
  oneof kind {
    VoteApprove approve = 1;
    VoteDeny deny = 2;
    VoteAbstain abstain = 3;
    VoteVeto veto = 4;
  }
}
message VoteKind {
  oneof kind {
    VoteKindElectorate electorate = 1;
    VoteKindVeto veto = 2;
  }
}
message Instructions {
  oneof instruction {
    CreateRealm create_realm = 1;
    DepositGoverningTokens deposit_governing_tokens = 2;
    WithdrawGoverningTokens withdraw_governing_tokens = 3;
    SetGovernanceDelegate set_governance_delegate = 4;
    CreateGovernance create_governance = 5;
    Legacy4 legacy4 = 6;
    CreateProposal create_proposal = 7;
    AddSignatory add_signatory = 8;
    Legacy1 legacy1 = 9;
    InsertTransaction insert_transaction = 10;
    RemoveTransaction remove_transaction = 11;
    CancelProposal cancel_proposal = 12;
    SignOffProposal sign_off_proposal = 13;
    CastVote cast_vote = 14;
    FinalizeVote finalize_vote = 15;
    RelinquishVote relinquish_vote = 16;
    ExecuteTransaction execute_transaction = 17;
    Legacy2 legacy2 = 18;
    Legacy3 legacy3 = 19;
    SetGovernanceConfig set_governance_config = 20;
    Legacy5 legacy5 = 21;
    SetRealmAuthority set_realm_authority = 22;
    SetRealmConfig set_realm_config = 23;
    CreateTokenOwnerRecord create_token_owner_record = 24;
    UpdateProgramMetadata update_program_metadata = 25;
    CreateNativeTreasury create_native_treasury = 26;
    RevokeGoverningTokens revoke_governing_tokens = 27;
    RefundProposalDeposit refund_proposal_deposit = 28;
    CompleteProposal complete_proposal = 29;
    AddRequiredSignatory add_required_signatory = 30;
    RemoveRequiredSignatory remove_required_signatory = 31;
    SetTokenOwnerRecordLock set_token_owner_record_lock = 32;
    RelinquishTokenOwnerRecordLocks relinquish_token_owner_record_locks = 33;
    SetRealmConfigItem set_realm_config_item = 34;
  }
}
