  uint64 total_staking_rewards = 6;
  uint64 withdraw_amount = 7;
  int64 withdraw_time = 8;
}

message WithdrawStakeEvent {
  WithdrawStakeEventAccounts accounts = 1;
  WithdrawStakeEventArgs args = 2;
}

message DelegateStakeEventAccounts {
  repeated PublicKey remaining_accounts = 1;
}

message DelegateStakeEventArgs {
  PublicKey custody = 1;
  PublicKey stake_account = 2;
  PublicKey stake_info = 3;
  uint64 custody_total_staked_amount = 4;
  uint64 stake_amount = 5;
  PublicKey validator_vote_account = 6;
  int64 delegate_time = 7;
}

message DelegateStakeEvent {
  DelegateStakeEventAccounts accounts = 1;
  DelegateStakeEventArgs args = 2;
}

message WithdrawFeesEventAccounts {
  repeated PublicKey remaining_accounts = 1;
}

message WithdrawFeesEventArgs {
  PublicKey pool = 1;
  PublicKey custody = 2;
  PublicKey custody_mint = 3;
  PublicKey receiving_token_account = 4;
  uint64 total_trade_swap_fees = 5;
  uint64 pool_trade_swap_fees = 6;
  uint64 protocol_trade_swap_fees = 7;
  uint64 total_borrow_lending_fees = 8;
  uint64 pool_borrow_lending_fees = 9;
  uint64 protocol_borrow_lending_fees = 10;
  uint64 pool_total_fees_usd = 11;
  uint64 apr_bps_before = 12;
  uint64 apr_bps_after = 13;
  int64 apr_bps_updated_at = 14;
  uint64 pool_realized_fee_usd_before = 15;
  uint64 pool_realized_fee_usd_after = 16;
  int64 curtime = 17;
}

message WithdrawFeesEvent {
  WithdrawFeesEventAccounts accounts = 1;
  WithdrawFeesEventArgs args = 2;
}

message ProgramEvents {
  oneof instruction {
    CreatePositionRequestEvent create_position_request_event = 1;
    InstantCreateTpslEvent instant_create_tpsl_event = 2;
    InstantUpdateTpslEvent instant_update_tpsl_event = 3;
    ClosePositionRequestEvent close_position_request_event = 4;
    IncreasePositionEvent increase_position_event = 5;
    IncreasePositionPreSwapEvent increase_position_pre_swap_event = 6;
    DecreasePositionEvent decrease_position_event = 7;
    DecreasePositionPostSwapEvent decrease_position_post_swap_event = 8;
    LiquidateFullPositionEvent liquidate_full_position_event = 9;
    PoolSwapEvent pool_swap_event = 10;
    PoolSwapExactOutEvent pool_swap_exact_out_event = 11;
    AddLiquidityEvent add_liquidity_event = 12;
    RemoveLiquidityEvent remove_liquidity_event = 13;
    InstantCreateLimitOrderEvent instant_create_limit_order_event = 14;
    InstantIncreasePositionEvent instant_increase_position_event = 15;
    InstantDecreasePositionEvent instant_decrease_position_event = 16;
    DepositCollateralEvent deposit_collateral_event = 17;
    WithdrawCollateralEvent withdraw_collateral_event = 18;
    BorrowFromCustodyEvent borrow_from_custody_event = 19;
    RepayToCustodyEvent repay_to_custody_event = 20;
    LiquidateBorrowPositionEvent liquidate_borrow_position_event = 21;
    RedeemStakeEvent redeem_stake_event = 22;
    WithdrawStakeEvent withdraw_stake_event = 23;
    DelegateStakeEvent delegate_stake_event = 24;
    WithdrawFeesEvent withdraw_fees_event = 25;
  }
}

message ProgramEventOutput {
  optional Instructions instruction = 1;
  repeated ProgramEvents program_events = 2;
}
